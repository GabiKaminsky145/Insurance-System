      "name": "Create Product (Admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type",      "value": "application/json"    },
          { "key": "X-Admin-Username",  "value": "{{adminUsername}}"   },
          { "key": "X-Admin-Password",  "value": "{{adminPassword}}"   }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"p1\",\n  \"name\": \"Life Insurance\",\n  \"description\": \"Basic coverage\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": ["{{baseUrl}}"],
          "path": ["api", "products"]
        }
      },
      "response": []
    },
    {
      "name": "Create Product — Wrong Admin Credentials (Negative Test)",
      "request": {
