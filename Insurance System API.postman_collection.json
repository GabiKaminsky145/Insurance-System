        "header": [
          { "key": "Content-Type",      "value": "application/json" },
          { "key": "X-Admin-Username",  "value": "admin"            },
          { "key": "X-Admin-Password",  "value": "wrongpassword"    }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"p2\",\n  \"name\": \"Health Insurance\",\n  \"description\": \"Should fail\"\n}"
